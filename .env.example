# Docker Compose
POSTGRES_USER=status
POSTGRES_PASSWORD=nekonekostatus
POSTGRES_DB=status
PORT=5555

# https://github.com/ewehiuw3743283478/status
GITHUB_REPO=ewehiuw3743283478/status

# Panel image (GitHub Container Registry, built by Actions):
# https://github.com/ewehiuw3743283478/status/pkgs/container/status
APP_IMAGE=ghcr.io/ewehiuw3743283478/status:latest
PULL_POLICY=always

# Agent binaries (GitHub Releases):
# https://github.com/ewehiuw3743283478/status/releases/latest/download/status-agent_linux_{amd64|arm64}

# Leave APP_IMAGE unset to build locally: docker compose up -d --build

# App (set automatically in docker-compose)
# DATABASE_URL=postgres://status:nekonekostatus@db:5432/status
# HOST=0.0.0.0

# Manual install without Docker (SQLite fallback)
# SQLITE_PATH=./database/db.db